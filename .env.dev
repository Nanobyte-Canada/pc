# Development Environment (VPS: devpc.nanobyte.ca)
# Secrets are managed via GitHub Secrets and passed during deployment

# Database Configuration
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
# POSTGRES_PASSWORD should come from GitHub Secrets

# Application Configuration
APP_VERSION=${APP_VERSION}
APP_ENVIRONMENT=dev

# Spring Configuration
SPRING_PROFILES_ACTIVE=dev

# Frontend Configuration
VITE_API_URL=https://devpc.nanobyte.ca

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://devpc.nanobyte.ca

# SnapTrade Configuration
SNAPTRADE_REDIRECT_URI=https://devpc.nanobyte.ca/brokers/connections
