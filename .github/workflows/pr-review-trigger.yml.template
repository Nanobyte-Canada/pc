# Copy this file to your repo as .github/workflows/pr-review-trigger.yml
# and configure the LLM_API_KEY secret in your repo settings.

name: PR Review

on:
  pull_request:
    branches: [main, develop]

permissions:
  contents: read
  pull-requests: write

jobs:
  review:
    uses: ./.github/workflows/pr-review.yml
    with:
      config_path: '.github/review-config.yml'
      fail_on_high: true
    secrets:
      api_key: ${{ secrets.OPENCODE_API_KEY }}
